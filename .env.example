# Copy to .env and customize
USER1_NAME=alice
USER1_PASSWORD=changeme1
USER2_NAME=bob
USER2_PASSWORD=changeme2

# Used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Set to 1 only when serving over HTTPS (e.g. behind a reverse proxy with TLS).
# Leave unset (or 0) for plain-HTTP localhost/LAN use, otherwise the browser
# will drop the session cookie and login will loop.
COOKIE_SECURE=0
